  "devDependencies": {
    "@rsbuild/core": "1.7.3",
    "babel-preset-cozy-app": "2.8.4",
    "cozy-app-publish": "0.44.1",
    "cozy-tsconfig": "1.8.1",
    "eslint": "10.7.0",
    "eslint-config-cozy-app": "7.1.0",
    "rsbuild-config-cozy-app": "0.8.0",
    "stylint": "1.5.9",
