    "cozy-flags": "^4.9.1",
    "cozy-intent": "^2.31.1",
    "cozy-interapp": "^0.18.0",
    "cozy-logger": "^1.18.1",
    "cozy-minilog": "^3.10.1",
    "cozy-pouch-link": "^60.29.0",
    "cozy-realtime": "^5.9.3",
    "cozy-search": "^2.0.11",
    "cozy-ui": "^140.5.2",
    "cozy-ui-plus": "^12.1.2",
